# ─────────────────────────────────────────────
# SUPABASE — Espace Membre
# https://supabase.com > Projet > Settings > API
# ─────────────────────────────────────────────
VITE_SUPABASE_URL=https://your_project_id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# ─────────────────────────────────────────────
# EmailJS — Variables d'environnement (exemple)
# Copiez ce fichier en .env et remplissez vos valeurs réelles.
# Récupérez-les sur https://www.emailjs.com/

VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# Template pour le formulaire de contact général (page Contact)
VITE_EMAILJS_TEMPLATE_CONTACT=your_template_contact_id_here

# Template pour les formulaires partenaires (page Partenaires)
VITE_EMAILJS_TEMPLATE_PARTNER=your_template_partner_id_here
